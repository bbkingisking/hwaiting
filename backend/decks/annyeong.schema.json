{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deck",
  "type": "object",
  "required": ["cards"],
  "properties": {
    "cards": {
      "type": "array",
      "items": {
        "title": "Card",
        "type": "object",
        "required": ["id", "form", "lemma", "pos", "senses"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "form": {
            "type": "string",
            "description": "The word as it appears in the example sentence (e.g. 폭풍, 못해요)"
          },
          "lemma": {
            "type": ["string", "null"],
            "description": "Dictionary form with optional particle notation (e.g. 폭풍+이). Null if unavailable."
          },
          "pos": {
            "type": ["string", "null"],
            "description": "Part of speech (e.g. noun, verb, present). Null if unspecified."
          },
          "senses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "title": "Sense",
              "type": "object",
              "required": ["translation", "translation_note", "example", "example_translation"],
              "properties": {
                "translation": {
                  "type": "string",
                  "description": "English gloss (e.g. storm, appears)"
                },
                "translation_note": {
                  "type": ["string", "null"],
                  "description": "Usage note (e.g. informal and polite speech). Null if none."
                },
                "example": {
                  "type": "string",
                  "description": "Example sentence in Korean"
                },
                "example_translation": {
                  "type": ["string", "null"],
                  "description": "English translation of the example sentence. Null if unavailable."
                }
              }
            }
          }
        }
      }
    }
  }
}